# Archon OAuth Server Configuration

# Server settings
PORT=3000
HOST_URL=http://localhost:3000

# Archon network
GATEKEEPER_URL=http://localhost:4224
WALLET_URL=https://wallet.archon.technology

# Wallet passphrase (required)
WALLET_PASSPHRASE=your-secure-passphrase-here

# Session secret (change in production!)
SESSION_SECRET=change-this-in-production

# CORS (comma-separated origins, or * for all)
CORS_ORIGIN=*

# Registry for new identity (hyperswarm, BTC, TFTC, etc.)
REGISTRY=hyperswarm
